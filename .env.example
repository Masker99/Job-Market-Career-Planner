# DeepSeek / LLM settings
# 真实调用模型时填写。不要把真实 API Key 提交到 GitHub。
DEEPSEEK_API_KEY=your_api_key_here

# 使用的 DeepSeek 模型名称。
DEEPSEEK_MODEL=deepseek-chat

# 生成温度。职业规划建议偏稳定，推荐 0.2-0.5。
DEEPSEEK_TEMPERATURE=0.3

# LLM 请求超时时间，单位秒。
DEEPSEEK_TIMEOUT=60

# LLM 请求失败时的最大重试次数。
DEEPSEEK_MAX_RETRIES=2

# 1 = mock 模式，不调用真实 LLM，适合学习、调试流程。
# 0 = 真实调用 DeepSeek，需要填写 DEEPSEEK_API_KEY。
JMCP_MOCK=1

# 岗位数据目录。
# 将你采集到的岗位 Markdown 数据放到 data/jobs/。
JMCP_JOB_DATA_DIR=data/jobs

# 简历/个人背景资料目录。
# 建议放 .txt 或 .md 文件，CLI 可通过 --resume-file 读取。
JMCP_RESUME_DIR=data/resume

# 检索时返回给 LLM 的岗位片段数量。
# 数值越大，上下文越丰富，但提示词也会更长。
JMCP_TOP_K=8

# V3 市场画像候选岗位数量。
# 系统会先从更多岗位中统计高频技能、标题、经验、学历和薪资，再选择代表性岗位给 LLM。
JMCP_MARKET_TOP_K=50

# V4 查询扩展模式。
# off = 保持 V3 行为；llm = 使用 LLM 改写/扩展检索词，mock 或失败时自动 fallback。
JMCP_QUERY_EXPANSION_MODE=llm

# 查询扩展最多参与检索的词数量。
JMCP_QUERY_EXPANSION_MAX_TERMS=30

# V5 检索模式。
# vector = 使用本地 embedding + simple vector search；keyword = 回退到 V4 关键词检索。
JMCP_RETRIEVAL_MODE=vector

# V5 本地 embedding 设置。hash 是零依赖、可复现的学习用 embedding。
JMCP_EMBEDDING_PROVIDER=hash
JMCP_EMBEDDING_DIMENSION=384
JMCP_VECTOR_INDEX_PATH=data/vector_index/jobs_embeddings.jsonl

# 职业规划领域。
# 可以改成：数据分析师、产品经理、Java 后端工程师等。
JMCP_DOMAIN=AI 应用工程师

# LLM 扮演的角色。
# 想支持多个领域时，保持通用即可。
JMCP_ADVISOR_ROLE=职业规划顾问

# CLI 没有传 --target-role 时使用的默认目标方向。
JMCP_DEFAULT_TARGET_ROLE=AI 应用工程师 / AI Agent 应用开发 / AI 自动化工程师

# 检索和规划时重点关注的关键词，用英文逗号分隔。
# 转换领域时，优先改这里。
JMCP_FOCUS_KEYWORDS=Python,RAG,Agent,FastAPI,Dify,n8n,Docker,RPA,API,LLM,LangChain,LangGraph,Coze,MCP,自动化,知识库,数据库

# 默认不优先推荐的方向，用英文逗号分隔。
# 如果不需要限制，可以留空。
JMCP_AVOID_DIRECTIONS=纯算法岗,大模型预训练岗,底层推理优化岗

# 输出语言。
JMCP_OUTPUT_LANGUAGE=zh-CN
